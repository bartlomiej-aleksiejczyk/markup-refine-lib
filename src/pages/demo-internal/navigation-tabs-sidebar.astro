          <button class="tab tab--active">test2</button>
        </div>
        <div class="stt-primary-sidebar-top">
          <h2>Manage Infobjects:</h2>
        </div>
        <div class="stt-primary-sidebar__list-container"></div>
      </div>
    </div>
