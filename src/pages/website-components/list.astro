---
import FullNavigationLayout from "../../astro/layouts/FullNavigationLayout.astro";
---

<FullNavigationLayout>
  <main class="responsive-container">
    <h1>Product List</h1>
    <ul>
      <li class="card positive">
        <span class="">Product 1</span>
        <p>Amazing product with top-notch features.</p>
      </li>
      <li class="card info">
        <span class="">Product 2</span>
        <p>Reliable and efficient solution for your needs.</p>
      </li>
      <li class="card warning">
        <span class="">Product 3</span>
        <p>Warning: Limited stock available!</p>
      </li>
      <li class="card negative">
        <span class="">Product 4</span>
        <p>Out of stock. Check back soon!</p>
      </li>
    </ul>
  </main>

  <footer>
    <p>&copy; 2025 MySite. All rights reserved.</p>
  </footer>
</FullNavigationLayout>
